---
import "../styles/global.css";
import "../styles/next.css";
import Comparator from "../components/Comparator.tsx";
import Support from "../components/Support.astro";
import { CHANGELOG } from "../data/changelog";

const latestChange = CHANGELOG[0];
const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const wave = Array.from({ length: 42 });
const stats = [
  { n: "3", plus: "+1", l: "engines", sub: "on-device, plus your own server" },
  { n: "99", l: "languages", sub: "auto-detected as you speak" },
  { n: "0", l: "accounts", sub: "no sign-up, no telemetry" },
  { n: "$0", l: "forever", sub: "free & MIT-licensed" },
];

// The capabilities carousel (design: Home.dc.html). One pane per feature; the rail
// below mirrors the same list as clickable cards with an auto-advance progress bar.
const features = [
  { num: "01", name: "Live transcript", title: "Live transcript",
    body: "Watch the words build up in the indicator as you speak — Parakeet streams the transcript in real time, so you're never staring at a spinner waiting for the result.",
    cap: "streaming · ~200 ms behind your voice",
    viz: `<div class="vz vz-type">Send the quarterly report to the team<span class="dc-caret"></span></div>` },
  { num: "02", name: "Record your way", title: "Record your way",
    body: "A key combo or a single modifier — hold to speak, release to insert. The indicator lives where you want it: near the cursor, at a screen edge, or docked in the notch / Dynamic Island, with optional Stop / Cancel buttons on the bubble.",
    cap: "the pill follows your cursor · Stop / Cancel buttons are opt-in",
    viz: `<div class="cursor-demo"><span class="nb-pill"><span class="rec-dot"></span>Recording…<span class="nb-btns"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.8"/><rect x="8.5" y="8.5" width="7" height="7" rx="1.2" fill="currentColor"/></svg><svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M9 3h6l1 2h4v2H4V5h4l1-2zm-3 6h12l-.9 11.1A2 2 0 0 1 15.1 22H8.9a2 2 0 0 1-2-1.9L6 9zm4 2v8h1.5v-8H10zm3 0v8h1.5v-8H13z"/></svg></span></span><svg class="cursor-arrow" viewBox="0 0 24 24" aria-hidden="true"><path d="M5.5 3.2v17.6c0 .45.54.67.85.35l4.13-4.13c.1-.1.22-.15.36-.15h5.83c.45 0 .67-.54.35-.85L6.35 2.85c-.31-.31-.85-.09-.85.35z" fill="#16151a" stroke="#fff" stroke-width="1.6" stroke-linejoin="round"/></svg></div>` },
  { num: "03", name: "Translate", title: "Translate as you speak",
    body: "Dictate in any of ~99 languages and get clean English out in a single shortcut — Whisper handles the recognition and the translation in one pass.",
    cap: "",
    viz: `<div class="vz vz-tr"><span class="vz-from">« Envoyez le rapport avant ce soir »</span><span class="vz-arrow">→</span><span class="vz-to">“Send the report by tonight.”</span></div>` },
  { num: "04", name: "Dictionary", title: "Custom dictionary",
    body: "Teach it your proper nouns and jargon — names, acronyms, product names — and they come out verbatim every time instead of being mangled into something close.",
    cap: "boosts recognition + applies replacements",
    viz: `<div class="vz vz-chips"><span>Kubernetes</span><span>OAuth2</span><span>Saanvi</span><span>GraphQL</span><span>My-Monkey</span></div>` },
  { num: "05", name: "Drop the filler", title: "Drop the filler",
    body: "Strips “um”, “uh” and the other verbal tics automatically, fixes sentence spacing, and never pastes “No speech detected” into your document when you pause.",
    cap: "",
    viz: `<div class="vz vz-filler"><span class="vz-strike">um,</span> <span class="vz-strike">so like,</span> just send it <span class="vz-strike">you know</span> <span class="vz-arrow">→</span> <b>Just send it.</b></div>` },
  { num: "06", name: "AI cleanup", title: "AI cleanup via Ollama",
    body: "Punctuation, casing and rambling, tidied by a local Ollama model running on your own machine. Your words never leave your Mac.",
    cap: "opt-in · fully on-device",
    viz: `<div class="vz vz-clean"><span class="cd-before">um so like send the the report to alex ok</span><span class="vz-arrow">↓ Ollama</span><span class="cd-after">Send the report to Alex.</span></div>` },
  { num: "07", name: "Model per app", title: "Model per app",
    body: "Bind a model to an app — or a website in supported browsers — and it switches automatically when you dictate there. A fast model for chat, an accurate one for email, a specialized one for your editor.",
    cap: "Rules · switches at record-start, from the menu bar",
    viz: `<div class="vz vz-chips"><span>Mail → Whisper large</span><span>Slack → Parakeet</span><span>docs.google.com → Remote</span></div>` },
  { num: "08", name: "History", title: "History that remembers",
    body: "Every dictation records where it happened — app, window, site — and which model transcribed it. Failed dictations keep their audio with a retry button instead of vanishing.",
    cap: "rerun ↻ with any model · or turn history off entirely",
    viz: `<div class="vz vz-chips"><span>Mail · 12s · Parakeet v3</span><span>github.com · 31s · Whisper</span></div>` },
  { num: "09", name: "Your server", title: "Bring your own server",
    body: "Point the Remote engine at any OpenAI-compatible endpoint — Groq, LiteLLM, speaches, a box on your LAN. If your server is unreachable, an optional on-device fallback transcribes anyway.",
    cap: "Groq preset + your own presets · local fallback",
    viz: `<div class="vz vz-cli"><span class="prompt">›</span> http://litellm.docker.lan · whisper-large-v3</div>` },
  { num: "10", name: "CLI & hooks", title: "Scriptable CLI",
    body: "A real command-line tool ships in the app bundle. Transcribe files from the terminal, pipe the text anywhere, and run your own command after each dictation with the post-record hook.",
    cap: "text + audio path via env vars · JSON on stdin",
    viz: `<div class="vz vz-cli"><span class="prompt">$</span> opensuperwhisper transcribe note.m4a &gt; note.txt</div>` },
];

const engines = [
  { name: "Whisper", desc: "The reference. ~99 languages, six sizes, can translate to English.", cloud: false },
  { name: "Parakeet", desc: "Fast, with a live preview as you speak. 25 European languages.", cloud: false },
  { name: "SenseVoice", desc: "Non-autoregressive and quick — Chinese, Cantonese, English, Japanese, Korean.", cloud: false },
  { name: "Remote", desc: "Any OpenAI-compatible server — Groq preset, LiteLLM, or your own box. With a local fallback if it's unreachable.", cloud: true },
];

const shots = [
  { img: "/screenshots/history.png", alt: "Transcription history", cap: "History", g: "",
    title: "A history that remembers",
    body: "Every dictation with its source app, site, duration and the model that transcribed it. Rerun any entry with a different model — or turn history off entirely." },
  { img: "/screenshots/remote-engine.png", alt: "Remote engine settings", cap: "Remote engine", g: "g2",
    title: "Any server, your rules",
    body: "Point it at any OpenAI-compatible endpoint, test the connection, pick from the server's speech-to-text models. Save your own presets; fall back to a local model if the server is down." },
  { img: "/screenshots/app-context.png", alt: "Rules — per-app and per-site model rules", cap: "Rules", g: "g3",
    title: "The right model, per app",
    body: "Bind a model to an app or a website and it switches automatically when you dictate there — managed here or from the menu-bar picker." },
  { img: "/screenshots/recording-settings.png", alt: "Dictation settings", cap: "Dictation", g: "g4",
    title: "Tune how you record",
    body: "Combo or single-modifier shortcut, hold-to-record, indicator position — cursor, screen edge or notch — and optional Stop / Cancel buttons on the bubble." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OpenSuperWhisper — Free Voice Dictation for Mac · SuperWhisper Alternative</title>
    <meta name="description" content="OpenSuperWhisper is the free, open-source alternative to SuperWhisper — voice dictation in any app on your Mac, with four on-device engines. No subscription, no account. Compare the models head-to-head." />
    <link rel="icon" href="/icon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <link rel="canonical" href="https://opensuperwhisper.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://opensuperwhisper.com/" />
    <meta property="og:title" content="OpenSuperWhisper — Free, Open-Source SuperWhisper Alternative for Mac" />
    <meta property="og:description" content="Speak, it types — in any app on your Mac. The free, open-source alternative to SuperWhisper: four engines, fully on-device, no subscription, no account." />
    <meta property="og:image" content="https://opensuperwhisper.com/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;680&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script defer src="https://uuu.my-monkey.fr/u.js" data-website-id="6734df40-5bb0-485e-a311-6ee24b1c7dc7"></script>
  </head>
  <body>
    <nav class="nav">
      <a class="brand" href="/"><img src="/icon.png" alt="" class="brand-icon" />OpenSuperWhisper</a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#compare">Compare</a>
        <a href="#engines">Engines</a>
        <a href="#screenshots">Screenshots</a>
        <a href="/changelog">Changelog</a>
        <a href="https://github.com/my-monkeys/OpenSuperWhisper" data-umami-event="github" data-umami-event-loc="nav">GitHub</a>
        <a class="btn btn-primary nav-cta" href="#get" data-umami-event="download-cta" data-umami-event-loc="nav">Download</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="wrap">
        <div class="hero-grid">
          <div class="nx-intro">
            <p class="eyebrow">Free · Open-source · 100% on-device</p>
            <h1 class="display">Speak. It types.<br />On your Mac, for free.</h1>
            <p class="lead hero-lead">Your voice into text in any app — four transcription engines, running on your machine. No subscription, no account, nothing leaves your Mac unless you point it at your own server.</p>
            <div class="hero-actions">
              <div class="cmd"><span class="prompt">$</span> brew install --cask my-monkeys/tap/opensuperwhisper</div>
              <a class="btn btn-ghost" href="https://github.com/my-monkeys/OpenSuperWhisper/releases" data-umami-event="download" data-umami-event-loc="hero">Download the .dmg</a>
            </div>
            <p class="hero-sub">Apple Silicon &amp; Intel · macOS 14+ · MIT licensed</p>
            <p class="hero-alt">The free, open-source <strong>SuperWhisper alternative</strong> — <a href="/superwhisper-alternative" data-umami-event="vs-superwhisper" data-umami-event-loc="hero">see how they compare →</a></p>
          </div>
          <div class="hero-visual">
            <span class="float-chip chip-1">Docks in the notch · Dynamic Island</span>
            <div class="nx-recorder">
              <div class="nx-rec-head">
                <span class="dc-rec"><span class="dc-dot"></span> Listening…</span>
                <span class="badge">● Parakeet · on-device</span>
              </div>
              <div class="nx-wave">{wave.map((_, i) => <span style={`animation-delay:${(i % 11) * 0.07}s;animation-duration:${0.9 + (i % 5) * 0.13}s`}></span>)}</div>
              <p class="nx-rec-text">Send the quarterly report to the team before <span class="dc-type">end of day</span><span class="dc-caret"></span></p>
              <div class="nx-rec-foot"><span>⌘V — pasted into Slack</span><span class="dc-check">✓</span></div>
            </div>
            <span class="float-chip chip-2">Hold ⌥ — release to paste</span>
          </div>
        </div>
      </div>
    </section>

    <section class="stats-band">
      <div class="wrap stat-strip">
        {stats.map((s) => (
          <div class="stat">
            <strong>{s.n}{s.plus && <em class="stat-plus">{s.plus}</em>}</strong>
            <span>{s.l}</span>
            <small>{s.sub}</small>
          </div>
        ))}
      </div>
    </section>

    <section id="features" class="crsec">
      <div class="section-glow sg-tr" aria-hidden="true"></div>
      <div class="wrap">
        <p class="eyebrow">More than a transcriber</p>
        <div class="cr-head">
          <div>
            <h2 class="h2">It doesn't just type. It polishes.</h2>
            <p class="lead cr-lead">Everything runs on your Mac — even the LLM cleanup, through your own <a href="https://ollama.com">Ollama</a>. The cloud is one optional engine, never a requirement.</p>
          </div>
          <div class="cr-arrows">
            <button class="cr-arrow" id="cr-prev" aria-label="Previous feature">←</button>
            <button class="cr-arrow" id="cr-next" aria-label="Next feature">→</button>
          </div>
        </div>

        <div class="cr-panes" id="cr-panes" data-on="0">
          {features.map((f, i) => (
            <div class={`crp p${i}`}>
              <div>
                <span class="crp-num">{f.num} / 10</span>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
                {f.cap && <span class="crp-cap">{f.cap}</span>}
              </div>
              <div set:html={f.viz} />
            </div>
          ))}
        </div>

        <div class="cr-rail" id="cr-rail">
          {features.map((f, i) => (
            <button class={`cr-card ${i === 0 ? "on" : ""}`} data-i={i}>
              <span class="cr-num">{f.num}</span>
              <span class="cr-name">{f.name}</span>
              <span class="cr-prog"></span>
            </button>
          ))}
        </div>
      </div>
    </section>

    <section id="compare" class="compare">
      <div class="section-glow sg-bl" aria-hidden="true"></div>
      <div class="wrap">
        <p class="eyebrow">The part nobody else shows you</p>
        <h2 class="h2">Which model should you use?</h2>
        <p class="lead section-lead">
          Faster or more accurate? On-device or your server? Does it even speak your language? Pick a
          language and compare every engine head-to-head.
        </p>
        <Comparator client:load />
      </div>
    </section>

    <section id="engines" class="engines">
      <div class="wrap">
        <p class="eyebrow">Four engines, one app</p>
        <h2 class="h2">Choose the trade-off that fits.</h2>
        <div class="engine-grid">
          {engines.map((e) => (
            <div class="engine-card">
              <div class="engine-top">
                <h3>{e.name}</h3>
                <span class="badge" data-cloud={e.cloud}>{e.cloud ? "☁ Your server" : "● On-device"}</span>
              </div>
              <p>{e.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="screenshots" class="shots">
      <div class="wrap">
        <p class="eyebrow">See it for real</p>
        <h2 class="h2">Not mockups. The actual app.</h2>
        {shots.map((s, i) => (
          <div class={`shot-row ${i % 2 ? "rev" : ""}`}>
            <div class={`shot-fig ${s.g}`}>
              <button class="shot-zoom" type="button" aria-label={`View ${s.cap} full size`}>
                <img src={s.img} alt={s.alt} loading="lazy" width="780" height="656" />
              </button>
            </div>
            <div class="shot-txt">
              <span class="shot-cap">{s.cap}</span>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="lb" id="lightbox" hidden>
        <button class="lb-x" type="button" aria-label="Close">✕</button>
        <button class="lb-nav lb-prev" type="button" aria-label="Previous screenshot">‹</button>
        <img alt="" />
        <button class="lb-nav lb-next" type="button" aria-label="Next screenshot">›</button>
        <span class="lb-count" aria-live="polite"></span>
      </div>
    </section>

    <section id="privacy" class="privacy">
      <div class="wrap">
        <p class="eyebrow">Private by default</p>
        <h2 class="h2">Your voice stays on your Mac.</h2>
        <div class="pv-grid">
          <div class="pv"><span class="pv-k">01 — ON-DEVICE</span><h3>Nothing leaves by default</h3><p>Three of the four engines run entirely on your machine. No account, no telemetry, no analytics in the app.</p></div>
          <div class="pv"><span class="pv-k">02 — EXPLICIT</span><h3>The cloud is opt-in, and labeled</h3><p>The only network path is the Remote engine — which you configure yourself, and which says plainly where your audio goes.</p></div>
          <div class="pv"><span class="pv-k">03 — YOURS</span><h3>History you control</h3><p>Keep everything, cap it by count or age, or turn it off entirely — nothing is persisted.</p></div>
        </div>
      </div>
    </section>

    <section id="selfhost">
      <div class="wrap">
        <p class="eyebrow">For power users</p>
        <h2 class="h2">Self-host it. Script it.</h2>
        <div class="sh-grid">
          <div class="sh-card">
            <h3>Bring your own server</h3>
            <p>LiteLLM, speaches, or a GPU box on your LAN — any OpenAI-compatible endpoint works, with saved presets and an on-device fallback.</p>
            <div class="vz vz-cli"><span class="prompt">›</span> http://litellm.docker.lan/v1 · whisper-large-v3</div>
            <span class="crp-cap">test connection · filtered model list · local fallback</span>
          </div>
          <div class="sh-card">
            <h3>Pipe it anywhere</h3>
            <p>The CLI ships in the app bundle — transcribe files from the terminal, get JSON, or run your own command after each dictation.</p>
            <div class="vz vz-cli"><span class="prompt">$</span> opensuperwhisper transcribe note.m4a &gt; note.txt</div>
            <span class="crp-cap">--json output · post-record hook · logs on stderr</span>
          </div>
        </div>
      </div>
    </section>

    <section id="whatsnew" class="whatsnew">
      <div class="wrap whatsnew-inner">
        <p class="eyebrow">Latest update</p>
        <a class="wn-card" href="/changelog" data-umami-event="changelog" data-umami-event-loc="home">
          <div class="cl-meta">
            <span class="cl-ver">v{latestChange.version}</span>
            <time class="cl-date" datetime={latestChange.date}>{fmtDate(latestChange.date)}</time>
          </div>
          <h2 class="wn-title">{latestChange.title}</h2>
          <p class="wn-sum">{latestChange.summary}</p>
          <span class="wn-more">See all changes →</span>
        </a>
      </div>
    </section>

    <section id="get" class="get">
      <div class="section-glow sg-c" aria-hidden="true"></div>
      <div class="wrap get-inner">
        <h2 class="h2">Open. Yours. On your Mac.</h2>
        <p class="lead">A maintained, open-source successor — seven interface languages, a command-line tool, auto-updates. Free, forever.</p>
        <div class="hero-actions">
          <div class="cmd"><span class="prompt">$</span> brew install --cask my-monkeys/tap/opensuperwhisper</div>
          <a class="btn btn-primary" href="https://github.com/my-monkeys/OpenSuperWhisper/releases" data-umami-event="download" data-umami-event-loc="get">Download for macOS</a>
        </div>
      </div>
    </section>

    <section id="feedback" class="feedback">
      <div class="section-glow sg-bl" aria-hidden="true"></div>
      <div class="wrap fb-inner">
        <h2 class="h2">We're in beta — help us shape it</h2>
        <p class="lead">OpenSuperWhisper gets better with your feedback. Found a bug, or have an idea? Tell us — every report helps us build something more stable.</p>
        <form id="fb-form" class="fb-form">
          <textarea id="fb-message" name="message" rows="4" required maxlength="4000" placeholder="What works, what doesn't, what you'd love to see…"></textarea>
          <div class="fb-row">
            <input id="fb-email" name="email" type="email" maxlength="200" placeholder="Email (optional — only if you'd like a reply)" />
            <button class="btn btn-primary" type="submit" id="fb-submit">Send feedback</button>
          </div>
          <p class="fb-status" id="fb-status" role="status" aria-live="polite"></p>
        </form>
        <p class="fb-alt">Technical? <a href="https://github.com/my-monkeys/OpenSuperWhisper/issues/new">Open a GitHub issue</a> · <a href="https://github.com/my-monkeys/OpenSuperWhisper/releases">Grab a beta build</a></p>
      </div>
    </section>

    <footer class="fe">
      <div class="wrap">
        <div class="fe-head">
          <div class="fe-brand">🐵 My-Monkey</div>
          <a class="fe-univ" href="https://my-monkey.fr/projets/" data-umami-event="my-monkey-universe">Tout l'univers →</a>
        </div>
        <p class="fe-about">OpenSuperWhisper was an abandoned project — <strong>My-Monkey</strong> picked up the fork and keeps it alive. We're a collective shipping free, open-source software: sometimes a little absurd, always ours.</p>
        <Support />
        <div class="fe-foot">
          <span>OpenSuperWhisper · MIT licensed</span>
          <a href="https://github.com/my-monkeys/OpenSuperWhisper" data-umami-event="github" data-umami-event-loc="footer">github.com/my-monkeys/OpenSuperWhisper</a>
        </div>
      </div>
    </footer>

    <script>
      // ── Screenshot lightbox — click any shot to see it full size, arrows to browse ──
      const lb = document.getElementById("lightbox");
      if (lb) {
        const lbImg = lb.querySelector("img");
        const lbCount = lb.querySelector(".lb-count");
        const shotImgs = Array.from(document.querySelectorAll(".shot-zoom img"));
        let lbIdx = 0;
        const showLb = (i) => {
          lbIdx = (i + shotImgs.length) % shotImgs.length;
          const img = shotImgs[lbIdx];
          lbImg.src = img.currentSrc || img.src;
          lbImg.alt = img.alt;
          lbCount.textContent = `${lbIdx + 1} / ${shotImgs.length}`;
        };
        const openLb = (i) => {
          showLb(i);
          lb.hidden = false;
          document.documentElement.style.overflow = "hidden";
        };
        const closeLb = () => {
          lb.hidden = true;
          document.documentElement.style.overflow = "";
        };
        document.querySelectorAll(".shot-zoom").forEach((btn, i) => {
          btn.addEventListener("click", () => openLb(i));
        });
        // clicking the backdrop or ✕ closes; the image and arrows must not bubble into that
        lb.addEventListener("click", closeLb);
        lbImg.addEventListener("click", (e) => e.stopPropagation());
        lb.querySelector(".lb-prev").addEventListener("click", (e) => { e.stopPropagation(); showLb(lbIdx - 1); });
        lb.querySelector(".lb-next").addEventListener("click", (e) => { e.stopPropagation(); showLb(lbIdx + 1); });
        window.addEventListener("keydown", (e) => {
          if (lb.hidden) return;
          if (e.key === "Escape") closeLb();
          else if (e.key === "ArrowLeft") showLb(lbIdx - 1);
          else if (e.key === "ArrowRight") showLb(lbIdx + 1);
        });
      }

      // ── Capabilities carousel (design: Home.dc.html) ─────────────────────────
      const N = 10;
      const HOLD = 5000;
      const sec = document.getElementById("features");
      const panes = document.getElementById("cr-panes");
      const rail = document.getElementById("cr-rail");
      const cards = Array.from(rail.querySelectorAll(".cr-card"));
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // One state machine for the timer + progress bar. While the pointer is over the
      // section (paused), a manual navigation must NOT start a frozen bar or re-arm the
      // timer — the fresh cycle is deferred to mouseleave (pending).
      let cur = 0, timer = null, armedAt = 0, remaining = HOLD, paused = false, pending = false;

      function clearBars() {
        cards.forEach((c) => { c.querySelector(".cr-prog").style.animation = "none"; });
      }

      function startCycle() {
        clearBars();
        clearTimeout(timer);
        if (reduced) return;
        const p = cards[cur].querySelector(".cr-prog");
        void p.offsetWidth; // reflow so the animation restarts from zero
        p.style.animation = `crProg ${HOLD}ms linear forwards`;
        armedAt = Date.now();
        remaining = HOLD;
        timer = setTimeout(() => show((cur + 1) % N), HOLD);
      }

      function show(n, scroll = true) {
        cur = n;
        panes.dataset.on = String(n);
        cards.forEach((c, k) => c.classList.toggle("on", k === n));
        if (scroll) {
          const c = cards[n];
          rail.scrollTo({ left: c.offsetLeft - rail.offsetWidth / 2 + c.offsetWidth / 2, behavior: "smooth" });
        }
        if (paused) {
          // Hovering: hold off — bar stays empty, timer silent, cycle starts on leave.
          clearBars();
          clearTimeout(timer);
          pending = true;
        } else {
          startCycle();
        }
      }

      document.getElementById("cr-prev").addEventListener("click", () => show((cur + N - 1) % N));
      document.getElementById("cr-next").addEventListener("click", () => show((cur + 1) % N));

      // Hover anywhere on the section pauses the auto-advance (and the progress bar).
      sec.addEventListener("mouseenter", () => {
        if (paused || reduced) return;
        paused = true;
        if (!pending) {
          remaining -= Date.now() - armedAt;
          clearTimeout(timer);
          cards[cur].querySelector(".cr-prog").style.animationPlayState = "paused";
        }
      });
      sec.addEventListener("mouseleave", () => {
        if (!paused) return;
        paused = false;
        if (pending) {
          pending = false;
          startCycle();
        } else {
          const p = cards[cur].querySelector(".cr-prog");
          p.style.animationPlayState = "running";
          armedAt = Date.now();
          remaining = Math.max(400, remaining);
          clearTimeout(timer);
          timer = setTimeout(() => show((cur + 1) % N), remaining);
        }
      });

      // Drag-to-scroll on the rail, without turning drags into card clicks.
      let drag = null, suppressClick = false;
      rail.addEventListener("pointerdown", (e) => { drag = { x: e.clientX, sl: rail.scrollLeft, moved: 0 }; });
      rail.addEventListener("pointermove", (e) => {
        if (!drag) return;
        const dx = e.clientX - drag.x;
        drag.moved = Math.max(drag.moved, Math.abs(dx));
        rail.scrollLeft = drag.sl - dx;
      });
      ["pointerup", "pointercancel"].forEach((ev) =>
        rail.addEventListener(ev, () => {
          suppressClick = !!drag && drag.moved > 6;
          drag = null;
          if (suppressClick) setTimeout(() => { suppressClick = false; }, 0);
        }));
      cards.forEach((c, k) => c.addEventListener("click", () => { if (!suppressClick) show(k); }));

      show(0, false);

      // ── Feedback form ────────────────────────────────────────────────────────
      const fbForm = document.getElementById("fb-form");
      if (fbForm) {
        const fbStatus = document.getElementById("fb-status");
        const fbSubmit = document.getElementById("fb-submit");
        fbForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const message = document.getElementById("fb-message").value.trim();
          const email = document.getElementById("fb-email").value.trim();
          if (message.length < 2) { fbStatus.textContent = "Please write a little more."; return; }
          fbSubmit.disabled = true; fbStatus.textContent = "Sending…";
          try {
            const res = await fetch("https://git.my-monkey.fr/api/feedback", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ message, email: email || undefined, product: "opensuperwhisper", context: "opensuperwhisper.com" }),
            });
            if (res.ok) { fbForm.reset(); fbStatus.textContent = "Thank you! Your feedback landed. 🍌"; }
            else { fbStatus.textContent = "Hmm, that didn't go through — please try again, or use GitHub Issues."; }
          } catch {
            fbStatus.textContent = "Network error — please try again, or use GitHub Issues.";
          } finally { fbSubmit.disabled = false; }
        });
      }
    </script>

