---
import "../styles/global.css";
import "../styles/next.css";
import Comparator from "../components/Comparator.tsx";
import Support from "../components/Support.astro";
import { CHANGELOG } from "../data/changelog";

const latestChange = CHANGELOG[0];
const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const engines = [
  { name: "Whisper", desc: "The reference. ~99 languages, six sizes, can translate to English.", tag: "on-device" },
  { name: "Parakeet", desc: "Fast, with a live preview as you speak. 25 European languages.", tag: "on-device" },
  { name: "SenseVoice", desc: "Non-autoregressive and quick — Chinese, Cantonese, English, Japanese, Korean.", tag: "on-device" },
  { name: "Remote", desc: "Any OpenAI-compatible server — Groq preset, LiteLLM, or your own box. Optional, with a local fallback if it's unreachable.", tag: "cloud" },
];
const wave = Array.from({ length: 42 });
const stats = [
  { n: "4", l: "engines" }, { n: "99", l: "languages" },
  { n: "0", l: "telemetry" }, { n: "$0", l: "forever" },
];
const I = {
  wand: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512"><path fill="currentColor" d="M263.4-27L278.2 9.8 315 24.6c3 1.2 5 4.2 5 7.4s-2 6.2-5 7.4L278.2 54.2 263.4 91c-1.2 3-4.2 5-7.4 5s-6.2-2-7.4-5L233.8 54.2 197 39.4c-3-1.2-5-4.2-5-7.4s2-6.2 5-7.4L233.8 9.8 248.6-27c1.2-3 4.2-5 7.4-5s6.2 2 7.4 5zM110.7 41.7l21.5 50.1 50.1 21.5c5.9 2.5 9.7 8.3 9.7 14.7s-3.8 12.2-9.7 14.7l-50.1 21.5-21.5 50.1c-2.5 5.9-8.3 9.7-14.7 9.7s-12.2-3.8-14.7-9.7L59.8 164.2 9.7 142.7C3.8 140.2 0 134.4 0 128s3.8-12.2 9.7-14.7L59.8 91.8 81.3 41.7C83.8 35.8 89.6 32 96 32s12.2 3.8 14.7 9.7zM464 304c6.4 0 12.2 3.8 14.7 9.7l21.5 50.1 50.1 21.5c5.9 2.5 9.7 8.3 9.7 14.7s-3.8 12.2-9.7 14.7l-50.1 21.5-21.5 50.1c-2.5 5.9-8.3 9.7-14.7 9.7s-12.2-3.8-14.7-9.7l-21.5-50.1-50.1-21.5c-5.9-2.5-9.7-8.3-9.7-14.7s3.8-12.2 9.7-14.7l50.1-21.5 21.5-50.1c2.5-5.9 8.3-9.7 14.7-9.7zM460 0c11 0 21.6 4.4 29.5 12.2l42.3 42.3C539.6 62.4 544 73 544 84s-4.4 21.6-12.2 29.5l-88.2 88.2-101.3-101.3 88.2-88.2C438.4 4.4 449 0 460 0zM44.2 398.5L308.4 134.3 409.7 235.6 145.5 499.8C137.6 507.6 127 512 116 512s-21.6-4.4-29.5-12.2L44.2 457.5C36.4 449.6 32 439 32 428s4.4-21.6 12.2-29.5z"/></svg>`,
  mic: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512"><path fill="currentColor" d="M96 96c0-53 43-96 96-96 50.3 0 91.6 38.7 95.7 88L232 88c-13.3 0-24 10.7-24 24s10.7 24 24 24l56 0 0 48-56 0c-13.3 0-24 10.7-24 24s10.7 24 24 24l55.7 0c-4.1 49.3-45.3 88-95.7 88-53 0-96-43-96-96L96 96zM24 160c13.3 0 24 10.7 24 24l0 40c0 79.5 64.5 144 144 144s144-64.5 144-144l0-40c0-13.3 10.7-24 24-24s24 10.7 24 24l0 40c0 97.9-73.3 178.7-168 190.5l0 49.5 48 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-144 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l48 0 0-49.5C73.3 402.7 0 321.9 0 224l0-40c0-13.3 10.7-24 24-24z"/></svg>`,
  language: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512"><path fill="currentColor" d="M160 0c17.7 0 32 14.3 32 32l0 32 128 0c17.7 0 32 14.3 32 32s-14.3 32-32 32l-9.6 0-8.4 23.1c-16.4 45.2-41.1 86.5-72.2 122 14.2 8.8 29 16.6 44.4 23.5l50.4 22.4 62.2-140c5.1-11.6 16.6-19 29.2-19s24.1 7.4 29.2 19l128 288c7.2 16.2-.1 35.1-16.2 42.2s-35.1-.1-42.2-16.2l-20-45-157.5 0-20 45c-7.2 16.2-26.1 23.4-42.2 16.2s-23.4-26.1-16.2-42.2l39.8-89.5-50.4-22.4c-23-10.2-45-22.4-65.8-36.4-21.3 17.2-44.6 32.2-69.5 44.7L78.3 380.6c-15.8 7.9-35 1.5-42.9-14.3s-1.5-35 14.3-42.9l34.5-17.3c16.3-8.2 31.8-17.7 46.4-28.3-13.8-12.7-26.8-26.4-38.9-40.9L81.6 224.7c-11.3-13.6-9.5-33.8 4.1-45.1s33.8-9.5 45.1 4.1l10.2 12.2c11.5 13.9 24.1 26.8 37.4 38.7 27.5-30.4 49.2-66.1 63.5-105.4l.5-1.2-210.3 0C14.3 128 0 113.7 0 96S14.3 64 32 64l96 0 0-32c0-17.7 14.3-32 32-32zM416 270.8L365.7 384 466.3 384 416 270.8z"/></svg>`,
  book: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"><path fill="currentColor" d="M384 512L96 512c-53 0-96-43-96-96L0 96C0 43 43 0 96 0L400 0c26.5 0 48 21.5 48 48l0 288c0 20.9-13.4 38.7-32 45.3l0 66.7c17.7 0 32 14.3 32 32s-14.3 32-32 32l-32 0zM96 384c-17.7 0-32 14.3-32 32s14.3 32 32 32l256 0 0-64-256 0zm32-232c0 13.3 10.7 24 24 24l176 0c13.3 0 24-10.7 24-24s-10.7-24-24-24l-176 0c-13.3 0-24 10.7-24 24zm24 72c-13.3 0-24 10.7-24 24s10.7 24 24 24l176 0c13.3 0 24-10.7 24-24s-10.7-24-24-24l-176 0z"/></svg>`,
  broom: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512"><path fill="currentColor" d="M566.6 54.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-192 192-34.7-34.7c-4.2-4.2-10-6.6-16-6.6-12.5 0-22.6 10.1-22.6 22.6l0 29.1 108.3 108.3 29.1 0c12.5 0 22.6-10.1 22.6-22.6 0-6-2.4-11.8-6.6-16l-34.7-34.7 192-192zM341.1 353.4L222.6 234.9c-42.7-3.7-85.2 11.7-115.8 42.3l-8 8c-22.3 22.3-34.8 52.5-34.8 84 0 6.8 7.1 11.2 13.2 8.2l51.1-25.5c5-2.5 9.5 4.1 5.4 7.9L7.3 473.4C2.7 477.6 0 483.6 0 489.9 0 502.1 9.9 512 22.1 512l173.3 0c38.8 0 75.9-15.4 103.4-42.8 30.6-30.6 45.9-73.1 42.3-115.8z"/></svg>`,
  dot: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path fill="currentColor" d="M256 512a256 256 0 1 0 0-512 256 256 0 1 0 0 512zm0-352a96 96 0 1 1 0 192 96 96 0 1 1 0-192z"/></svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path fill="currentColor" d="M256 0c4.6 0 9.2 1 13.4 2.9L457.8 82.8c22 9.3 38.4 31 38.3 57.2-.5 99.2-41.3 280.7-213.6 363.2-16.7 8-36.1 8-52.8 0-172.4-82.5-213.1-264-213.6-363.2-.1-26.2 16.3-47.9 38.3-57.2L242.7 2.9C246.9 1 251.4 0 256 0zm0 66.8l0 378.1c138-66.8 175.1-214.8 176-303.4l-176-74.6 0 0z"/></svg>`,
  terminal: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path fill="currentColor" d="M9.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L146.7 256 9.4 118.6zM224 384l256 0c17.7 0 32 14.3 32 32s-14.3 32-32 32l-256 0c-17.7 0-32-14.3-32-32s14.3-32 32-32z"/></svg>`,
};
const features = [
  { icon: I.mic, k: "Live transcript",
    long: "Watch the words build up in the indicator as you speak — Parakeet streams the transcript in real time, so you're never staring at a spinner waiting for the result.",
    viz: `<div class="vz vz-type">Send the quarterly report to the team<span class="dc-caret"></span></div><span class="vz-cap">streaming · ~200 ms behind your voice</span>` },
  { icon: I.language, k: "Translate as you speak",
    long: "Dictate in any of ~99 languages and get clean English out in a single shortcut — Whisper handles the recognition and the translation in one pass.",
    viz: `<div class="vz vz-tr"><span class="vz-from">« Envoyez le rapport avant ce soir »</span><span class="vz-arrow">→</span><span class="vz-to">“Send the report by tonight.”</span></div>` },
  { icon: I.wand, k: "AI cleanup via Ollama",
    long: "Punctuation, casing and rambling, tidied by a local Ollama model running on your own machine. Fully on-device and opt-in — your words never leave your Mac.",
    viz: `<div class="vz vz-clean"><span class="cd-before">um so like send the the report to alex ok</span><span class="vz-arrow">↓ Ollama</span><span class="cd-after">Send the report to Alex.</span></div>` },
  { icon: I.book, k: "Custom dictionary",
    long: "Teach it your proper nouns and jargon — names, acronyms, product names — and they come out verbatim every time instead of being mangled into something close.",
    viz: `<div class="vz vz-chips"><span>Kubernetes</span><span>OAuth2</span><span>Saanvi</span><span>GraphQL</span><span>My-Monkey</span></div><span class="vz-cap">recognised exactly as you spell them</span>` },
  { icon: I.broom, k: "Drop the filler",
    long: "Strips “um”, “uh” and the other verbal tics automatically, and never pastes “No speech detected” into your document when you pause.",
    viz: `<div class="vz vz-filler"><span class="vz-strike">um,</span> <span class="vz-strike">so like,</span> just send it <span class="vz-strike">you know</span> <span class="vz-arrow">→</span> <b>Just send it.</b></div>` },
  { icon: I.shield, k: "Private by default",
    long: "No account, no telemetry, no cloud unless you explicitly pick the Groq engine. Turn transcription history off entirely, or cap how long it's kept.",
    viz: `<div class="vz vz-badges"><span class="badge">● On-device</span><span class="badge">0 telemetry</span><span class="badge">No account</span></div>` },
  { icon: I.dot, k: "Model per app",
    long: "Bind a model to an app — or a website in supported browsers — and it switches automatically when you dictate there. A fast model for chat, an accurate one for email, a specialized one for your editor.",
    viz: `<div class="vz vz-chips"><span>Mail → Whisper large</span><span>Slack → Parakeet</span><span>docs.google.com → Remote</span></div><span class="vz-cap">switches at record-start, from the menu bar</span>` },
  { icon: I.wand, k: "Bring your own server",
    long: "Point the Remote engine at any OpenAI-compatible endpoint — Groq, LiteLLM, speaches, a box on your LAN. If your server is unreachable, an optional on-device fallback transcribes anyway.",
    viz: `<div class="vz vz-cli"><span class="prompt">›</span> http://litellm.docker.lan · whisper-large-v3</div><span class="vz-cap">your audio goes to <b>your</b> server — or nowhere</span>` },
  { icon: I.book, k: "History that remembers",
    long: "Every dictation records where it happened — app, window, site — and which model transcribed it. Rerun any entry with a different model, and failed dictations keep their audio with a retry button.",
    viz: `<div class="vz vz-chips"><span>Mail · 12s · Parakeet v3</span><span>github.com · 31s · Whisper</span></div><span class="vz-cap">rerun ↻ with any model, nothing lost</span>` },
  { icon: I.terminal, k: "Scriptable CLI",
    long: "A real command-line tool ships in the app bundle. Transcribe files from the terminal and pipe the text into anything — scripts, notes, your own tooling.",
    viz: `<div class="vz vz-cli"><span class="prompt">$</span> opensuperwhisper transcribe note.m4a &gt; note.txt</div>` },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OpenSuperWhisper — Free Voice Dictation for Mac · SuperWhisper Alternative</title>
    <meta name="description" content="OpenSuperWhisper is the free, open-source alternative to SuperWhisper — voice dictation in any app on your Mac, with four on-device engines. No subscription, no account. Compare the models head-to-head." />
    <link rel="icon" href="/icon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <link rel="canonical" href="https://opensuperwhisper.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://opensuperwhisper.com/" />
    <meta property="og:title" content="OpenSuperWhisper — Free, Open-Source SuperWhisper Alternative for Mac" />
    <meta property="og:description" content="Speak, it types — in any app on your Mac. The free, open-source alternative to SuperWhisper: four engines, fully on-device, no subscription, no account." />
    <meta property="og:image" content="https://opensuperwhisper.com/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;680&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script defer src="https://uuu.my-monkey.fr/u.js" data-website-id="6734df40-5bb0-485e-a311-6ee24b1c7dc7"></script>
  </head>
  <body>
    <nav class="nav">
      <a class="brand" href="/"><img src="/icon.png" alt="" class="brand-icon" />OpenSuperWhisper</a>
      <div class="nav-links">
        <a href="#compare">Compare models</a>
        <a href="#engines">Engines</a>
        <a href="/changelog">Changelog</a>
        <a href="https://github.com/my-monkeys/OpenSuperWhisper" data-umami-event="github" data-umami-event-loc="nav">GitHub</a>
        <a class="btn btn-primary nav-cta" href="#get" data-umami-event="download-cta" data-umami-event-loc="nav">Download</a>
      </div>
    </nav>

    <section class="nx-hero">
      <div class="nx-hero-sticky">
      <div class="nx-stage">
        <div class="nx-intro">
          <p class="eyebrow">Free · Open-source · 100% on-device</p>
          <h1 class="display">Speak. It types.<br />On your Mac, for free.</h1>
          <p class="lead">Your voice into text in any app — four transcription engines, running on your machine. No subscription, no account, nothing leaves your Mac unless you choose the cloud.</p>
          <div class="hero-actions">
            <div class="cmd"><span class="prompt">$</span> brew install --cask my-monkeys/tap/opensuperwhisper</div>
            <a class="btn btn-ghost" href="https://github.com/my-monkeys/OpenSuperWhisper/releases" data-umami-event="download" data-umami-event-loc="hero">Download the .dmg</a>
          </div>
          <p class="hero-sub">Apple Silicon &amp; Intel · macOS 14+ · MIT licensed</p>
          <p class="hero-alt">The free, open-source <strong>SuperWhisper alternative</strong> — <a href="/superwhisper-alternative" data-umami-event="vs-superwhisper" data-umami-event-loc="hero">see how they compare →</a></p>
        </div>
        <div class="nx-recorder" id="recorder">
          <div class="nx-rec-head">
            <span class="dc-rec"><span class="dc-dot"></span> Listening…</span>
            <span class="badge">● Parakeet · on-device</span>
          </div>
          <div class="nx-wave">{wave.map((_, i) => <span style={`animation-delay:${(i % 11) * 0.07}s;animation-duration:${0.9 + (i % 5) * 0.13}s`}></span>)}</div>
          <p class="nx-rec-text">Send the quarterly report to the team before <span class="dc-type">end of day</span><span class="dc-caret"></span></p>
          <div class="nx-rec-foot"><span>⌘V — pasted into Slack</span><span class="dc-check">✓</span></div>
        </div>
      </div>
      <div class="nx-scrollhint">scroll ↓</div>
      </div>
    </section>

    <section class="stats-band">
      <div class="wrap stat-strip">
        {stats.map((s) => (
          <div class="stat"><strong>{s.n}</strong><span>{s.l}</span></div>
        ))}
      </div>
    </section>

    <section id="compare" class="compare">
      <div class="section-glow sg-bl" aria-hidden="true"></div>
      <div class="wrap">
        <p class="eyebrow">The part nobody else shows you</p>
        <h2 class="h2">Which model should you use?</h2>
        <p class="lead section-lead">
          Faster or more accurate? On-device or cloud? Does it even speak your language? Pick a
          language and compare every engine head-to-head.
        </p>
        <Comparator client:load />
      </div>
    </section>

    <section id="features" class="nx-feat">
      <div class="section-glow sg-tr" aria-hidden="true"></div>
      <div class="wrap">
        <p class="eyebrow">More than a transcriber</p>
        <h2 class="h2">It doesn't just type. It polishes.</h2>
        <p class="lead nx-feat-lead">
          Everything runs on your Mac — even the LLM cleanup, through your own
          <a href="https://ollama.com">Ollama</a>. The cloud is one optional engine, never a requirement.
        </p>
        <div class="nx-tabs-grid">
          <div class="nx-tablist">
            {features.map((f, i) => (
              <button class={`nx-tab ${i === 0 ? "on" : ""}`} data-i={i}>
                <span class="feat-icon" set:html={f.icon} />
                <span class="nx-tab-k">{f.k}</span>
                <span class="nx-tab-prog"></span>
              </button>
            ))}
          </div>
          <div class="nx-panes">
            {features.map((f, i) => (
              <div class={`nx-pane ${i === 0 ? "on" : ""}`} data-i={i}>
                <div class="nx-pane-icon" set:html={f.icon} />
                <h3>{f.k}</h3>
                <p>{f.long}</p>
                <div class="nx-pane-viz" set:html={f.viz} />
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="engines" class="engines">
      <div class="wrap">
        <p class="eyebrow">Four engines, one app</p>
        <h2 class="h2">Choose the trade-off that fits.</h2>
        <div class="engine-grid">
          {engines.map((e) => (
            <div class="engine-card">
              <div class="engine-top">
                <h3>{e.name}</h3>
                <span class="badge" data-cloud={e.tag === "cloud"}>{e.tag === "cloud" ? "☁ Cloud" : "● On-device"}</span>
              </div>
              <p>{e.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="whatsnew" class="whatsnew">
      <div class="wrap whatsnew-inner">
        <p class="eyebrow">Latest update</p>
        <a class="wn-card" href="/changelog" data-umami-event="changelog" data-umami-event-loc="home">
          <div class="cl-meta">
            <span class="cl-ver">v{latestChange.version}</span>
            <time class="cl-date" datetime={latestChange.date}>{fmtDate(latestChange.date)}</time>
          </div>
          <h2 class="wn-title">{latestChange.title}</h2>
          <p class="wn-sum">{latestChange.summary}</p>
          <span class="wn-more">See all changes →</span>
        </a>
      </div>
    </section>

    <section id="get" class="get">
      <div class="section-glow sg-c" aria-hidden="true"></div>
      <div class="wrap get-inner">
        <h2 class="h2">Open. Yours. On your Mac.</h2>
        <p class="lead">A maintained, open-source successor — six interface languages, a command-line tool, auto-updates. Free, forever.</p>
        <div class="hero-actions">
          <div class="cmd"><span class="prompt">$</span> brew install --cask my-monkeys/tap/opensuperwhisper</div>
          <a class="btn btn-primary" href="https://github.com/my-monkeys/OpenSuperWhisper/releases" data-umami-event="download" data-umami-event-loc="get">Download for macOS</a>
        </div>
      </div>
    </section>

    <section id="feedback" class="feedback">
      <div class="section-glow sg-bl" aria-hidden="true"></div>
      <div class="wrap fb-inner">
        <h2 class="h2">We're in beta — help us shape it</h2>
        <p class="lead">OpenSuperWhisper gets better with your feedback. Found a bug, or have an idea? Tell us — every report helps us build something more stable.</p>
        <form id="fb-form" class="fb-form">
          <textarea id="fb-message" name="message" rows="4" required maxlength="4000" placeholder="What works, what doesn't, what you'd love to see…"></textarea>
          <div class="fb-row">
            <input id="fb-email" name="email" type="email" maxlength="200" placeholder="Email (optional — only if you'd like a reply)" />
            <button class="btn btn-primary" type="submit" id="fb-submit">Send feedback</button>
          </div>
          <p class="fb-status" id="fb-status" role="status" aria-live="polite"></p>
        </form>
        <p class="fb-alt">Technical? <a href="https://github.com/my-monkeys/OpenSuperWhisper/issues/new">Open a GitHub issue</a> · <a href="https://github.com/my-monkeys/OpenSuperWhisper/releases">Grab a beta build</a></p>
      </div>
    </section>

    <script>
      const fbForm = document.getElementById("fb-form");
      if (fbForm) {
        const fbStatus = document.getElementById("fb-status");
        const fbSubmit = document.getElementById("fb-submit");
        fbForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const message = document.getElementById("fb-message").value.trim();
          const email = document.getElementById("fb-email").value.trim();
          if (message.length < 2) { fbStatus.textContent = "Please write a little more."; return; }
          fbSubmit.disabled = true; fbStatus.textContent = "Sending…";
          try {
            const res = await fetch("https://git.my-monkey.fr/api/feedback", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ message, email: email || undefined, product: "opensuperwhisper", context: "opensuperwhisper.com" }),
            });
            if (res.ok) { fbForm.reset(); fbStatus.textContent = "Thank you! Your feedback landed. 🍌"; }
            else { fbStatus.textContent = "Hmm, that didn't go through — please try again, or use GitHub Issues."; }
          } catch {
            fbStatus.textContent = "Network error — please try again, or use GitHub Issues.";
          } finally { fbSubmit.disabled = false; }
        });
      }
    </script>

