    <script>
      import gsap from "gsap";
      import ScrollTrigger from "gsap/ScrollTrigger";
      gsap.registerPlugin(ScrollTrigger);

      // scroll-driven hero: recorder shrinks & docks right as the headline reveals
      if (window.matchMedia("(min-width: 900px)").matches) {
        const tl = gsap.timeline({
          scrollTrigger: { trigger: ".nx-hero", start: "top top", end: "bottom bottom", scrub: 0.7 },
        });
        tl.fromTo("#recorder", { scale: 1.34, xPercent: -64 }, { scale: 1, xPercent: 0, ease: "none" }, 0);
        tl.fromTo(".nx-intro", { autoAlpha: 0, x: -40 }, { autoAlpha: 1, x: 0, ease: "none" }, 0.34);
        tl.to(".nx-scrollhint", { autoAlpha: 0, ease: "none" }, 0.05);
      } else {
        gsap.set(".nx-intro", { autoAlpha: 1 });
      }

      // features: auto-sliding tabs. Progress bar drives the advance; hover pauses, click jumps.
      const tabs = Array.from(document.querySelectorAll(".nx-tab"));
      const panes = Array.from(document.querySelectorAll(".nx-pane"));
      let prog;
      const HOLD = 5;
      function show(n) {
        tabs.forEach((t, k) => t.classList.toggle("on", k === n));
        panes.forEach((p, k) => p.classList.toggle("on", k === n));
        gsap.fromTo(panes[n], { autoAlpha: 0.2, y: 16 }, { autoAlpha: 1, y: 0, duration: 0.45, ease: "power2.out" });
        if (prog) prog.kill();
        tabs.forEach((t) => gsap.set(t.querySelector(".nx-tab-prog"), { scaleX: 0 }));
        prog = gsap.fromTo(tabs[n].querySelector(".nx-tab-prog"),
          { scaleX: 0 }, { scaleX: 1, duration: HOLD, ease: "none", onComplete: () => show((n + 1) % tabs.length) });
      }
      tabs.forEach((t, k) => t.addEventListener("click", () => show(k)));
      const featSec = document.querySelector(".nx-feat");
      featSec.addEventListener("mouseenter", () => prog && prog.pause());
      featSec.addEventListener("mouseleave", () => prog && prog.resume());
      ScrollTrigger.create({ trigger: ".nx-feat", start: "top 75%", once: true, onEnter: () => show(0) });
    </script>
    <style>
      .hero-alt { margin-top: 12px; font-size: 0.92rem; color: var(--ink-2); }
      .hero-alt strong { color: var(--ink); font-weight: 600; }
      .hero-alt a { color: var(--accent); text-decoration: none; font-weight: 500; white-space: nowrap; }
      .hero-alt a:hover { text-decoration: underline; }
      .feedback { padding: 96px 0; position: relative; }
      .fb-inner { max-width: 720px; position: relative; }
      .fb-form { margin-top: 28px; display: grid; gap: 12px; }
      .fb-form textarea,
      .fb-form input {
        width: 100%; font: inherit; color: var(--ink);
        padding: 13px 15px; border-radius: 12px;
        border: 1px solid var(--line); background: var(--paper-2);
        transition: border-color .15s ease, background .15s ease;
      }
      .fb-form textarea { resize: vertical; min-height: 112px; line-height: 1.5; }
      .fb-form textarea::placeholder,
      .fb-form input::placeholder { color: var(--ink-3); }
      .fb-form textarea:focus,
      .fb-form input:focus { outline: none; border-color: var(--accent); background: #fff; }
      .fb-row { display: flex; gap: 12px; align-items: stretch; flex-wrap: wrap; }
      .fb-row input { flex: 1 1 280px; }
      .fb-row .btn { white-space: nowrap; }
      .fb-status { min-height: 1.2em; margin: 2px 0 0; font-size: .92rem; color: var(--ink-2); }
      .fb-alt { margin-top: 20px; font-size: .92rem; color: var(--ink-3); }
      .fb-alt a { color: var(--accent); text-decoration: none; }
      .fb-alt a:hover { text-decoration: underline; }
      @media (max-width: 560px) { .fb-row .btn { width: 100%; } }
    </style>
